# MySQL (default setup).

production:
  adapter: postgresql
  database: openproject
  host: 172.18.17.236
  username: openprojectsd
  password: dfltpwd
  # For MySQL 5.6 or older, set encoding to utf8.
  encoding: unicode

development:
  adapter: postgresql
  database: openproject_development
  host: 172.18.17.236
  username: openprojectsd
  password: dfltpwd
  # For MySQL 5.6 or older, set encoding to utf8.
  encoding: unicode

# Warning: The database defined as "test" will be erased and
# re-generated from your development database when you run "rake".
# Do not set this db to the same as development or production.
test:
  adapter: postgresql
  database: openproject_test
  host: 172.18.17.236
  username: openprojectsd
  password: dfltpwd
  # For MySQL 5.6 or older, set encoding to utf8.
  encoding: unicode
  pool: 20
