<% html_title 'Экран "Глава региона"'-%>
<div ng-app="OpenProjectLegacy" class="ng-scope">
  <div id="invisible-grid" class="widget-boxes project-overview">
    <div class="grid-block">
      <div style="flex: 0 0 33.3%; max-width: 33.3%;">
        <p style="text-align: center;font-weight: bold;margin: -2px;">Федеральный бюджет на 20151<br>Всего 5 млн. рублей</p>
        <wp-overview-status-diagram chart-data='[{"data":[64,32,15],"label":"false"}]'>
        </wp-overview-status-diagram>
      </div>
      <div style="flex: 0 0 33.3%; max-width: 33.3%;">
        <p style="text-align: center;font-weight: bold;margin: -2px;">Консолидированные бюджеты субъектов Российской Федерации на 20151<br>Всего 5 млн. рублей</p>
        <wp-overview-status-diagram chart-data='[{"data":[45,28,10],"label":"false"}]'>
        </wp-overview-status-diagram>
      </div>
      <div style="flex: 0 0 33.3%; max-width: 33.3%;">
        <p style="text-align: center;font-weight: bold;margin: -2px;">Внебюджетные источники на 20151<br>Всего 5 млн. рублей</p>
        <wp-overview-status-diagram chart-data='[{"data":[53,25,1],"label":"false"}]'>
        </wp-overview-status-diagram>
      </div>
    </div>
    <div>
      <wp-overview-date-diagram chart-labels='["Фактически исполнено","Риски исполнения","Остаток финансовых средств"]'>
      </wp-overview-date-diagram>
    </div>
  </div>
</div>
