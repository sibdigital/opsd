    .progress-label
    {
      position: relative;
      margin: auto;
    }
    .progress {
      height: 1em;
      width: 100%;
      background-color: #ffffff;
      border-radius: 10px;
      position: relative;
    }
    .progress:before {
      content: attr(data-label);
      font-size: 0.8em;
      position: absolute;
      text-align: center;
      border-radius: 10px;
      top: 1px;
      left: 0;
      right: 0;
    }
    .progress .value {
      background-color: #7cc4ff;
      display: block;
      border-radius: 10px;
      height: 100%;
    }
    .border-progress{
